{
  "name": "bracu-cf-assistant",
  "displayName": "BRACU Codeforces Assistant",
  "description": "Streamline Codeforces contests with automated login and problem pulling.",
  "version": "0.0.2",
  "publisher": "AbrarShahriar",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/AbrarShahriar/bracu-cf-assistant"
  },
  "engines": {
    "vscode": "^1.110.0"
  },
  "categories": [
    "Education",
    "Programming Languages"
  ],
  "keywords": [
    "Codeforces",
    "Competitive Programming",
    "BRACU",
    "Problem Puller",
    "Automation"
  ],
  "activationEvents": [
    "onLanguage:java"
  ],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "bracu-cf-assistant.login",
        "title": "BRACU-CF: Login"
      },
      {
        "command": "bracu-cf-assistant.pull",
        "title": "BRACU-CF: Pull Current Problem"
      },
      {
        "command": "bracu-cf-assistant.generateTests",
        "title": "BRACU-CF: Generate Custom Test Cases"
      },
      {
        "command": "bracu-cf-assistant.test",
        "title": "BRACU-CF: Run Solution Against Tests",
        "icon": "$(play)"
      },
      {
        "command": "bracu-cf-assistant.kill",
        "title": "BRACU-CF: Kill Browser Session (Optional)"
      }
    ],
    "menus": {
      "editor/title": [
        {
          "command": "bracu-cf-assistant.test",
          "group": "navigation",
          "when": "resourceExtname == .java"
        }
      ]
    },
    "keybindings": [
      {
        "command": "bracu-cf-assistant.test",
        "key": "ctrl+r",
        "mac": "cmd+r",
        "when": "editorTextFocus && resourceExtname == .java"
      }
    ],
    "configuration": {
      "title": "BRACU Codeforces Assistant",
      "properties": {
        "bracu-cf-assistant.browserChannel": {
          "type": "string",
          "enum": [
            "chrome",
            "msedge"
          ],
          "default": "chrome",
          "description": "Select which installed browser to use. Note: Browser must be installed on your system."
        }
      }
    }
  },
  "scripts": {
    "vscode:prepublish": "pnpm run compile",
    "compile": "tsc -p ./",
    "watch": "tsc -watch -p ./",
    "pretest": "pnpm run compile && pnpm run lint",
    "lint": "eslint src",
    "test": "vscode-test",
    "build-local": "pnpm run compile && npx @vscode/vsce package --no-dependencies --skip-license"
  },
  "devDependencies": {
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "@types/puppeteer": "^7.0.4",
    "@types/vscode": "^1.110.0",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1"
  },
  "dependencies": {
    "playwright-core": "^1.58.2",
    "playwright-extra": "^4.3.6",
    "puppeteer-extra-plugin-stealth": "^2.11.2"
  }
}
